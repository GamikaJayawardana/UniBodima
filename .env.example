# ---------------------------------------------------------------------------
# BoardingFor.me — environment variables
# Copy this file to `.env.local` and fill in real values.
# ---------------------------------------------------------------------------

# Public base URL of the deployed site (used for SEO: canonical URLs, sitemap,
# robots.txt, Open Graph tags, and JSON-LD structured data). No trailing slash.
NEXT_PUBLIC_SITE_URL=https://www.boardingfor.me

# MongoDB connection string (Atlas SRV or standard mongodb:// URI).
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/boardingfor
# Optional non-SRV fallback if DNS/SRV lookup fails on your network.
MONGODB_URI_FALLBACK=

# NextAuth — generate a secret with: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=https://www.boardingfor.me

# Google OAuth (optional — leave blank to disable Google sign-in).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Cloudinary (image uploads for listings).
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name

# Secret required to call GET /api/admin/seed?secret=... which creates/resets
# the "admin-gamika" super-admin account. Change this before going live.
ADMIN_SEED_SECRET=setup-boardingfor
